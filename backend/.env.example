# PostgreSQL 连接串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/psy_app?schema=public"

# JWT 配置
JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="7d"

# 老师后台密钥（通过 x-admin-secret 访问 /admin 接口）
ADMIN_SECRET="replace-with-admin-secret"

# 应用配置
PORT=3000
HOST="0.0.0.0"
CORS_ORIGIN="http://127.0.0.1:5173"
