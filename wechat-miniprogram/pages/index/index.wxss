.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f766e;
  margin-bottom: 16rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.stat-item {
  background: #f2fbf9;
  border: 1rpx solid #d4eee9;
  border-radius: 14rpx;
  padding: 14rpx;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f766e;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #537177;
}

.field-label {
  margin-top: 14rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #3c5460;
}

.picker {
  background: #f7fbfd;
  border: 1rpx solid #d8e6ec;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #1f3942;
}
