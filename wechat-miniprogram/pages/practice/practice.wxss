.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meta {
  color: #4d6b75;
  font-size: 24rpx;
}

.chapter {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #607d8b;
}

.stem {
  margin-top: 16rpx;
  font-size: 30rpx;
  line-height: 1.55;
  color: #1d2d35;
}

.option {
  display: flex;
  gap: 14rpx;
  padding: 16rpx;
  border: 1rpx solid #d9e7ec;
  border-radius: 14rpx;
  margin-bottom: 12rpx;
  background: #f9fcfd;
}

.option-selected {
  border-color: #0f766e;
  background: #e6f5f2;
}

.option-locked {
  opacity: 0.95;
}

.option-key {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #d7ece8;
  color: #0f766e;
  font-weight: 700;
  font-size: 24rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 26rpx;
  color: #1d3640;
  line-height: 1.5;
}

.short-input {
  width: 100%;
  min-height: 260rpx;
  background: #f8fcfd;
  border: 1rpx solid #d8e6ec;
  border-radius: 14rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.feedback-line {
  font-size: 25rpx;
  line-height: 1.6;
  color: #26424c;
  margin-bottom: 8rpx;
}

.feedback-ok {
  color: #087f5b;
}

.feedback-bad {
  color: #c92a2a;
}

.feedback-neutral {
  color: #0f766e;
}

.action-card button {
  margin-bottom: 12rpx;
}
